{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scoring Rubric Schema",
  "type": "object",
  "required": ["metadata","dimensions","process_score_formula","range"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version","name","description","use_case"],
      "properties": {
        "version": {"type":"string"},
        "name": {"type":"string"},
        "description": {"type":"string"},
        "use_case": {"type":"string"},
        "created_date": {"type":"string"}
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id","name","description","criteria"],
        "properties": {
          "id": {"type":"string"},
          "name": {"type":"string"},
          "description": {"type":"string"},
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["score","label","definition"],
              "properties": {
                "score": {"type":"number","minimum":0.0,"maximum":1.0},
                "label": {"type":"string"},
                "definition": {"type":"string"}
              }
            }
          }
        }
      }
    },
    "process_score_formula": {"type":"string"},
    "range": {
      "type": "object",
      "required": ["min","max"],
      "properties": {"min":{"type":"number"},"max":{"type":"number"}}
    }
  }
}
