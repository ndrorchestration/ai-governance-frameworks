{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Benchmark Tasks Schema",
  "type": "object",
  "required": ["metadata","tasks","rubric_alignment"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version","name","description","use_case"],
      "properties": {
        "version": {"type":"string"},
        "name": {"type":"string"},
        "description": {"type":"string"},
        "use_case": {"type":"string"},
        "created_date": {"type":"string"}
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id","category","dimension_tested","title","prompt"],
        "properties": {
          "task_id": {"type":"string","pattern":"^T_[A-Z]+_[0-9]{3}$"},
          "category": {"type":"string"},
          "dimension_tested": {"type":"string"},
          "title": {"type":"string"},
          "prompt": {"type":"string"},
          "expected_behaviors": {"type":"array","items":{"type":"string"}},
          "failure_modes": {"type":"array","items":{"type":"string"}}
        }
      }
    },
    "rubric_alignment": {"type":"object"}
  }
}
